{
  "name": "imagn",
  "version": "0.1.0",
  "description": "Multi-model image generation CLI",
  "license": "MIT",
  "author": "Henrique Ferrer",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/henriquerferrer/imagn.git"
  },
  "type": "module",
  "bin": {
    "imagn": "dist/cli.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "CHANGELOG.md",
    "README.md"
  ],
  "scripts": {
    "start": "tsx src/cli.ts",
    "test": "vitest run",
    "test:integration": "vitest run tests/integration",
    "smoke": "tsx scripts/smoke.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json && chmod +x dist/cli.js",
    "prepare": "npm run build"
  },
  "dependencies": {
    "citty": "^0.1.6",
    "@iarna/toml": "^2.2.5"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.19.0",
    "typescript": "~5.9.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18"
  }
}
